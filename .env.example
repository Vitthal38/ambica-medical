# ============================================================================
#  Ambica Medical — Environment Variables
#  Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# ============================================================================

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string. Examples:
#   Local: postgresql://postgres:postgres@localhost:5432/ambica?schema=public
#   Neon:  postgresql://user:pass@ep-xxxx.neon.tech/ambica?sslmode=require
#   Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ambica?schema=public"

# --- Auth -------------------------------------------------------------------
# A 32+ character random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET_32_CHARS_MINIMUM"

# --- Initial admin seed (used by `npm run prisma:seed`) ---------------------
SEED_ADMIN_EMAIL="admin@ambicamedical.in"
SEED_ADMIN_PASSWORD="ChangeMeBeforeDeploy!"

# --- File storage -----------------------------------------------------------
# Directory for prescription uploads. MUST be outside `public/`.
# Default if unset: ./.private/prescriptions
PRESCRIPTION_STORAGE_DIR=".private/prescriptions"
