# ============================================================================
#  Ambica Medical — Environment Variables
# ============================================================================
#
#  Copy this file to `.env` and fill in REAL values. NEVER commit `.env`.
#  This template documents every variable the app reads and any constraints
#  the code enforces (length, entropy, etc.).
#
#  Production values must come from your platform's secret store (Vercel /
#  Render environment variables UI) — never from a file checked into git.
# ============================================================================


# --- Database ---------------------------------------------------------------
#
# PostgreSQL connection URL. The app uses Prisma with prepared statements,
# so this is the only DB knob you need.
#
#   • Use a non-superuser role in production with the minimum privileges
#     required: SELECT / INSERT / UPDATE / DELETE on the app schema only.
#     NEVER use the `postgres` superuser in prod.
#   • Use ?sslmode=require for all managed providers. (Render adds this on
#     the internal URL automatically.)
#   • Keep the role's password ≥24 chars, generated, not memorable.
#
# Examples:
#   Local:       postgresql://postgres:postgres@localhost:5432/ambica?schema=public
#   Render:      postgresql://<user>:<pass>@<host>/ambica?sslmode=require
#   Neon:        postgresql://<user>:<pass>@<host>.neon.tech/ambica?sslmode=require
#   Supabase:    postgresql://postgres:<pass>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ambica?schema=public"


# --- Auth -------------------------------------------------------------------
#
# JWT signing key. The auth code enforces BOTH:
#   • length ≥ 32 characters
#   • Shannon entropy ≥ 96 bits (rejects "aaaaa..." type values)
#
# Generate a fresh secret per environment (dev / staging / prod):
#
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
# ROTATE this if a teammate leaves, a backup leaks, or you suspect compromise.
# Rotation invalidates every active session (users re-login).
AUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_BASE64URL_VALUE"


# --- Initial admin seed (used only by `npm run prisma:seed`) ----------------
#
# Bootstrap the first admin account. After first deploy:
#   • Set these to strong values in your secret manager.
#   • In production, the seed will REFUSE to run with the default password
#     "change-me-now-12345" or any password shorter than 12 chars.
#   • Re-running the seed in production ONLY rotates the admin password —
#     it never re-enables a deactivated account or changes the role.
SEED_ADMIN_EMAIL="admin@ambicamedical.in"
SEED_ADMIN_PASSWORD="ChangeMeBeforeDeploy_UseStrongPassword!"


# --- File storage -----------------------------------------------------------
#
# Directory for prescription uploads. MUST be outside `public/` (which Next
# serves statically and would expose PHI). The default below stays within the
# project but in a private subdirectory that is gitignored.
#
# Production: switch to a managed object store (S3 / R2 / Vercel Blob /
# Render Object Storage) and replace the implementation in `src/lib/storage.ts`.
# The interface is small — `put / get / remove` — so the swap is mechanical.
PRESCRIPTION_STORAGE_DIR=".private/prescriptions"


# --- Payments: Razorpay (feat/payments — TEST MODE FIRST) -------------------
#
# Get these from https://dashboard.razorpay.com after completing KYC.
# Use the rzp_test_ keys until the full flow is verified, then switch to live.
#
#   • KEY_ID is sent to the browser to open Razorpay Checkout — it is public.
#   • KEY_SECRET is server-only. NEVER expose it client-side, NEVER commit it.
#     Used to (a) create orders and (b) verify the payment signature.
#   • WEBHOOK_SECRET signs Razorpay webhooks. Set the SAME value in the
#     Razorpay dashboard → Webhooks. Every webhook is verified against it.
#
# Settlement: customer money is collected by Razorpay and paid out to the
# BANK ACCOUNT you register during KYC — NOT to any UPI ID placed in code.
# To receive into the account behind a UPI like vitthal.misal@ybl, register
# that account's bank details as your Razorpay settlement account.
#
# RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
# RAZORPAY_KEY_SECRET="REPLACE_SERVER_ONLY_SECRET"
# RAZORPAY_WEBHOOK_SECRET="REPLACE_WEBHOOK_SIGNING_SECRET"
# NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"   # public key, client bundle
#
# Checkout reservation window (minutes) — order auto-expires + stock restored.
# CHECKOUT_RESERVATION_MINUTES="5"


# --- Logging (optional) -----------------------------------------------------
#
# Threshold for the structured logger in src/lib/logger.ts.
#   debug | info | warn | error
# Defaults: `info` in production, `debug` otherwise.
# LOG_LEVEL="info"


# --- Runtime mode (set automatically by hosts) ------------------------------
#
# Vercel / Render set this to "production" on deploy. Do NOT set it manually
# in your local .env — that disables source maps, dev-tools, and friendly
# error pages. The app uses it to decide:
#   • cookie Secure flag (true in prod)
#   • HSTS header inclusion
#   • whether to leak stack traces in error responses (NEVER in prod)
#   • seed-time refusal of weak admin passwords
# NODE_ENV="development"
