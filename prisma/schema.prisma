// ============================================================================
//  Ambica Medical — Admin / CRM schema
// ============================================================================
//  Powers the internal pharmacy CRM: customers, prescriptions, orders, refills.
//  The public storefront does NOT read from these tables — it stays on the
//  static catalog JSON. Only the admin module touches Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MANAGER
  PHARMACIST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  /// bcrypt hash — never returned to the client
  passwordHash String
  name         String
  role         Role     @default(PHARMACIST)
  active       Boolean  @default(true)
  lastLoginAt  DateTime?

  /// Brute-force defense: monotonic counter of consecutive failed logins.
  /// Reset to 0 on every successful auth. Used together with `lockedUntil`.
  failedLoginCount Int       @default(0)
  /// When non-null and in the future, the account refuses logins regardless of
  /// password correctness. Set by the login route after N consecutive failures.
  lockedUntil      DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdCustomers     Customer[]      @relation("CustomerCreatedBy")
  uploadedPrescriptions Prescription[] @relation("PrescriptionUploadedBy")
  createdOrders        Order[]         @relation("OrderCreatedBy")
  recordedMedicineEntries MedicineEntry[] @relation("MedicineEntryRecordedBy")
  auditEvents          AuditLog[]      @relation("AuditActor")
}

// ---------------------------------------------------------------------------
// Audit log — immutable record of sensitive admin actions
// ---------------------------------------------------------------------------
//
// HIPAA-style principle: every access to PHI (read or write) is logged with
// actor, action, target, source IP, user-agent, timestamp.
//
// NEVER updated, NEVER deleted by the app. Schema has no `updatedAt` and the
// service layer only inserts. Tampering should require direct DB access, which
// would itself be detected by Postgres audit + backup integrity checks.
//
// `target` columns identify the affected entity. `meta` is an opaque JSON
// blob for action-specific context (NEVER store passwords or raw PHI here —
// only IDs, masked identifiers, and outcome data).

/// Approval workflow for medicine images. Drives the admin review queue.
///
/// - PENDING       : new admin upload of unknown provenance; awaits pharmacist
///                   review before going live on the storefront.
/// - APPROVED      : pharmacist (or auto-rule when source is trusted AND OCR
///                   composite confidence >= 0.85) has cleared the image.
/// - REJECTED      : pharmacist marked the image as wrong/illegible/dupe.
///                   Bytes stay in storage for audit; imagePublicUrl is cleared
///                   so the storefront falls back to the SVG placeholder.
/// - NEEDS_REVIEW  : OCR confidence 0.50-0.84 OR perceptual-hash collision
///                   with another SKU. Same shelf as PENDING but flagged.
enum ImageApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVIEW
}

/// Copyright basis under which we hold the image. Distinct from imageSource
/// (where it came from); records our LEGAL right to display.
enum ImageCopyrightStatus {
  UNKNOWN
  OWNED_BY_PHARMACY        /// own photography of in-stock pack
  MANUFACTURER_AUTHORIZED  /// written permission on file (link in imageSourceUrl)
  DISTRIBUTOR_CONTRACT     /// distributor agreement covers media rights
  STOCK_LICENSED           /// stock-photo licence (id in imageSourceUrl)
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGIN_LOCKED
  LOGOUT
  CUSTOMER_CREATE
  CUSTOMER_UPDATE
  CUSTOMER_DELETE
  CUSTOMER_VIEW
  PRESCRIPTION_CREATE
  PRESCRIPTION_VIEW
  PRESCRIPTION_FILE_DOWNLOAD
  MEDICINE_ENTRY_CREATE
  MEDICINE_ENTRY_UPDATE
  MEDICINE_ENTRY_DELETE
  MEDICINE_IMAGE_UPLOAD
  MEDICINE_IMAGE_DELETE
  MEDICINE_IMAGE_VERIFY
  MEDICINE_IMAGE_APPROVE
  MEDICINE_IMAGE_REJECT
  ORDER_CREATE
  ORDER_UPDATE
  CSRF_REJECTED
  RATE_LIMIT_HIT
  AUTH_DENIED
}

model AuditLog {
  id        String      @id @default(cuid())
  ts        DateTime    @default(now())
  action    AuditAction
  /// Acting user — nullable for anonymous events (failed logins).
  actorId   String?
  actor     User?       @relation("AuditActor", fields: [actorId], references: [id])
  /// Acting account's email (snapshotted so log survives user deletion).
  actorEmail String?
  /// What was acted upon (free-form discriminator + id).
  targetType String?
  targetId   String?
  /// Best-effort source IP (first hop of X-Forwarded-For).
  ip        String?
  /// User agent string (truncated to 512 chars at service layer).
  userAgent String?
  /// Correlation id from middleware — joins app logs to audit rows.
  requestId String?
  /// JSON metadata. Service layer is responsible for never inserting raw PHI.
  meta      Json?

  @@index([ts])
  @@index([action, ts])
  @@index([actorId, ts])
  @@index([targetType, targetId])
}

// ---------------------------------------------------------------------------
// Customers
// ---------------------------------------------------------------------------

model Customer {
  id        String   @id @default(cuid())
  /// Free-text full name. Indexed for prefix search.
  name      String
  /// 10-digit Indian mobile (validated at API). Unique per pharmacy.
  phone     String   @unique
  email     String?
  /// Stored as ISO date. May be null for legacy walk-ins.
  dob       DateTime?
  address   String?
  notes     String?
  /// Soft delete — keep history for compliance.
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id])

  prescriptions   Prescription[]
  orders          Order[]
  refillReminders RefillReminder[]
  medicineEntries MedicineEntry[]

  // Phone and name are the two hot search paths.
  @@index([phone])
  @@index([name])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Medicines
// ---------------------------------------------------------------------------
// Mirrors the public catalog SKUs so orders/prescriptions can link by id.
// Synced from the catalog (script can upsert from medicines.json + products.json).

model Medicine {
  id            String   @id           // matches catalog id (MED-XXXX or pXXX)
  slug          String   @unique
  name          String                  // generic name (e.g. "Paracetamol 500mg")
  brand         String
  manufacturer  String?
  category      String
  subcategory   String?
  dosage        String?
  dosageForm    String?
  pack          String
  rxRequired    Boolean  @default(false)
  mrp           Int
  price         Int

  // ---------- Image management ----------------------------------------
  // Legacy / catalog-supplied URL. May point to /medicines/<id>.jpg in
  // public/ OR to a manufacturer URL. Wins over `imageStorageKey` until
  // the admin uploads a verified replacement.
  imageUrl      String?

  // Admin-uploaded image (post-validation, post-sharp-optimization).
  // Storage backend is decided at runtime: Vercel Blob in prod, local
  // FS in dev. The KEY is opaque to the app — only the storage adapter
  // knows how to dereference it.
  imageStorageKey String?
  imagePublicUrl  String?      // denormalized fast-path for storefront reads
  imageMime       String?      // 'image/webp' typically, post-optimization
  imageWidth      Int?
  imageHeight     Int?
  imageBytes      Int?         // post-optimization byte size
  // 64-bit perceptual hash, hex. Catches near-duplicates across the
  // catalog (same pack-shot uploaded for two SKUs by mistake).
  imagePhash      String?
  // SHA-256 of the optimized bytes — exact-duplicate detection +
  // change detection for cache invalidation.
  imageSha256     String?
  // Provenance — required for D&C audit + future image-rights review.
  // Values: 'admin_upload' | 'manufacturer' | 'own_photo' | 'stock_licensed'
  imageSource     String?
  // Optional attribution URL (manufacturer's product page, stock license
  // certificate, etc.). NEVER a scraped competitor URL.
  imageSourceUrl  String?
  // 0-100 admin confidence rating. 100 = verified by pharmacist as the
  // correct pack for this SKU; 0 = guess.
  imageConfidence Int?
  // When non-null, a pharmacist has reviewed and approved the image.
  // The storefront should prefer verified uploads over legacy catalog URLs.
  imageVerifiedAt DateTime?
  // When non-null, the optimization pipeline last processed this image.
  // Used by the re-optimization cron to find stale images after a
  // sharp version bump or quality preset change.
  imageOptimizedAt DateTime?

  // ---------- Approval workflow + provenance (Phase 1 + Phase 4) ------------

  /// Where this image sits in the review queue.
  approvalStatus    ImageApprovalStatus  @default(PENDING)
  /// Why we believe we have the right to display this image. Distinct from
  /// `imageSource` (where it came from); records our LEGAL basis.
  copyrightStatus   ImageCopyrightStatus @default(UNKNOWN)
  /// Free-text explanation when `approvalStatus = REJECTED`. Capped at the
  /// API layer to keep audit rows compact.
  rejectionReason   String?
  /// User id of the staff member who photographed this pack — populated by
  /// the bulk-import when source = own_photo and the operator passed
  /// --photographer=<email>. Optional otherwise.
  photographerId    String?

  // ---------- OCR (Phase 3) -------------------------------------------------

  /// Raw text Tesseract pulled off the pack — first 2 KB, for grep + debug.
  /// Never displayed verbatim on the storefront. May contain garbage tokens.
  ocrExtractedText  String?
  /// When OCR last ran against this image's source bytes. Re-OCR on swap.
  ocrMatchedAt      DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  prescriptions   PrescriptionMedicine[]
  orderItems      OrderItem[]
  refillReminders RefillReminder[]
  medicineEntries MedicineEntry[]

  @@index([name])
  @@index([brand])
  @@index([category])
  // Find products that need image work (no verified image yet)
  @@index([imageVerifiedAt])
  // Duplicate detection across the catalog
  @@index([imagePhash])
  // Approval queue: cheap "show me everything in PENDING / NEEDS_REVIEW".
  @@index([approvalStatus])
}

// ---------------------------------------------------------------------------
// Prescriptions
// ---------------------------------------------------------------------------

enum PrescriptionStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

model Prescription {
  id          String              @id @default(cuid())
  customerId  String
  customer    Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  /// e.g. "Dr. Anil Kulkarni, MD"
  doctorName  String?
  doctorReg   String?  // medical council registration
  issueDate   DateTime
  /// ~6 months from issueDate for most Rx in India. Used for refill checks.
  expiryDate  DateTime?

  /// Internal storage key. Either:
  ///   - "db"      — bytes live in `fileBytes` column (new uploads since 2026-05;
  ///                 the only path that works on Vercel)
  ///   - <path>    — legacy filesystem key; read via the storage adapter
  /// The download route handles both — see readPrescriptionFile().
  storageKey  String

  /// Prescription file bytes, stored inline so the system works on serverless
  /// hosts without an object-store provisioned. PHI lives in the same DB as
  /// the rest of the patient record — fewer vendor handoffs, better data
  /// residency. Capped to 5 MB at upload (see MAX_FILE_SIZE).
  ///
  /// NEVER include in default selects — Prisma would haul the bytes into
  /// memory on every list query. The download route fetches this column
  /// explicitly; everywhere else omits it.
  fileBytes   Bytes?
  /// "image/jpeg" | "image/png" | "application/pdf"
  mimeType    String
  /// In bytes
  fileSize    Int
  /// SHA-256 of the file — used to dedupe re-uploads of the same scan.
  fileHash    String?

  status      PrescriptionStatus @default(ACTIVE)
  notes       String?

  uploadedById String?
  uploadedBy   User?    @relation("PrescriptionUploadedBy", fields: [uploadedById], references: [id])

  medicines   PrescriptionMedicine[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([expiryDate])
  @@index([status])
}

/// Many-to-many between prescriptions and the medicines they cover.
model PrescriptionMedicine {
  prescriptionId String
  medicineId     String
  /// Dosage instructions for this Rx line — "1 tab, 0-0-1, after food".
  dosageNote     String?
  /// Number of days the prescription covers this medicine. Drives refill due.
  durationDays   Int?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicine     Medicine     @relation(fields: [medicineId], references: [id])

  @@id([prescriptionId, medicineId])
  @@index([medicineId])
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  COD
  STORE
}

model Order {
  id            String        @id @default(cuid())
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  /// Human-readable order code, e.g. "AMB-100234". Unique.
  code          String        @unique

  placedAt      DateTime      @default(now())
  status        OrderStatus   @default(CONFIRMED)
  paymentMethod PaymentMethod @default(STORE)

  /// Money totals in paise to avoid floating-point bugs. /100 to display.
  subtotalPaise Int
  discountPaise Int           @default(0)
  deliveryPaise Int           @default(0)
  totalPaise    Int

  notes         String?

  createdById   String?
  createdBy     User?         @relation("OrderCreatedBy", fields: [createdById], references: [id])

  items         OrderItem[]
  refillReminders RefillReminder[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId, placedAt])
  @@index([placedAt])
  @@index([status])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  medicineId    String
  medicine      Medicine @relation(fields: [medicineId], references: [id])

  /// Snapshot of name/brand at purchase time — protects against future renames.
  nameSnapshot  String
  brandSnapshot String

  quantity      Int
  unitPricePaise Int
  totalPaise    Int

  @@index([orderId])
  @@index([medicineId])
}

// ---------------------------------------------------------------------------
// Refill reminders
// ---------------------------------------------------------------------------

enum ReminderStatus {
  PENDING
  SENT
  FULFILLED
  DISMISSED
}

enum ReminderChannel {
  NONE       // dashboard-only
  SMS
  WHATSAPP
  EMAIL
}

model RefillReminder {
  id          String         @id @default(cuid())
  customerId  String
  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  medicineId  String
  medicine    Medicine       @relation(fields: [medicineId], references: [id])

  /// The order whose stock is running out. Optional — manual reminders allowed.
  sourceOrderId String?
  sourceOrder   Order?       @relation(fields: [sourceOrderId], references: [id])

  dueOn       DateTime
  status      ReminderStatus  @default(PENDING)
  channel     ReminderChannel @default(NONE)
  message     String?

  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dueOn, status])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Medicine entries — direct/manual medicine records on a customer
// ---------------------------------------------------------------------------
//
//  Adds a way for pharmacy staff to log medicines sold/dispensed to a customer
//  WITHOUT requiring a prescription upload. Used for OTC sales, walk-ins, and
//  quick repeat-customer entries.
//
//  Intentionally NOT linked to Prescription or Order — those flows are
//  unchanged. Reads on the medicine timeline merge entries with order items.

enum EntryType {
  PRESCRIPTION   // recorded against a verified prescription (manually re-keyed)
  MANUAL         // pharmacist-entered without a paper Rx (repeat customer, etc.)
  OTC            // over-the-counter sale
}

model MedicineEntry {
  id          String    @id @default(cuid())

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  medicineId  String
  medicine    Medicine  @relation(fields: [medicineId], references: [id])

  /// How many units (strips, bottles, etc.) dispensed.
  quantity    Int

  /// Free-text dosage instructions e.g. "1-0-1 after food, 5 days".
  dosage      String?

  /// Optional pharmacist note.
  notes       String?

  /// When the dispensing happened. May be back-dated.
  entryDate   DateTime  @default(now())

  /// Origin of this entry — used for timeline badges + analytics.
  entryType   EntryType @default(MANUAL)

  recordedById String?
  recordedBy   User?    @relation("MedicineEntryRecordedBy", fields: [recordedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId, entryDate])
  @@index([medicineId])
  @@index([entryType])
}
